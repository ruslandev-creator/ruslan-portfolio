# Telegram bot sozlamalari (aloqa formasi uchun)
# Bu qiymatlarni HECH QACHON koda yozmang. Faqat .env.local (mahalliy) va
# Vercel -> Settings -> Environment Variables ga qo'ying.

# @BotFather bergan token (masalan: 123456789:AA...)
TELEGRAM_BOT_TOKEN=

# Xabar boradigan chat ID (sizning Telegram ID'ingiz, masalan: 123456789)
TELEGRAM_CHAT_ID=
